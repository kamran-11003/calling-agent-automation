# Twilio credentials are now stored per-agent in the database (encrypted).
# Users enter their own Twilio Account SID + Auth Token in the agent builder UI.
# No global Twilio credentials needed here.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Encryption key for stored API keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# App
APP_URL=https://your-backend.railway.app
PORT=8000
ENVIRONMENT=development
